# Custom container for visual regression testing of the GNOME extension.
# Extends gnome-shell-pod-rawhide — no Python backend needed for UI tests.

FROM ghcr.io/schneegans/gnome-shell-pod-rawhide

# Install ImageMagick for screenshot comparison
USER root
RUN dnf install -y --nogpgcheck ImageMagick && dnf clean all

# Copy the project source
COPY . /app
WORKDIR /app

# Build the GNOME extension ZIP
RUN python3 /app/tests/gnome-tests/build-ext-zip.py

# Ensure output directories exist
RUN mkdir -p /app/tests/gnome-output

# Switch back to gnomeshell user for runtime
USER gnomeshell
WORKDIR /home/gnomeshell
